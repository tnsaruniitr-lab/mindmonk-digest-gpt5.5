{
  "name": "youtube-digest-bot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "pm2": "pm2 start npm --name mindmonk -- run start",
    "pm2:stop": "pm2 stop mindmonk",
    "pm2:logs": "pm2 logs mindmonk",
    "pm2:restart": "pm2 restart mindmonk"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.0",
    "ffmpeg-static": "^5.3.0",
    "node-cron": "^3.0.0",
    "pg": "^8.22.0",
    "rss-parser": "^3.13.0",
    "telegraf": "^4.16.0",
    "youtube-captions-scraper": "^2.0.3",
    "youtube-transcript": "^1.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
